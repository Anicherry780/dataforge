# DataForge Environment Configuration
# Copy to .env and fill in your values

# Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Database
DB_PATH=./dataforge.db

# CORS (comma-separated origins; use * for development only)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,https://etl.anirudhdev.com

# Pipeline defaults
DEFAULT_BATCH_SIZE=500
MAX_RECORDS_PER_RUN=50000

# Observability (optional)
# SENTRY_DSN=https://...
# OTEL_ENDPOINT=http://otel-collector:4317
